# ---------------------------------------------------------
# Python
# ---------------------------------------------------------
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
dist/
*.egg-info/
.eggs/
.pytest_cache/
.mypy_cache/
.ruff_cache/
htmlcov/
.coverage
.coverage.*
coverage.xml

# ---------------------------------------------------------
# Virtual environments
# ---------------------------------------------------------
venv/
.venv/
env/
ENV/

# ---------------------------------------------------------
# Secrets / environment config
# ---------------------------------------------------------
.env
.env.*
!.env.example

# ---------------------------------------------------------
# Data — raw and processed data shouldn't be committed.
# Keep the folders in git via .gitkeep, ignore their contents.
# ---------------------------------------------------------
data/raw/*
!data/raw/.gitkeep
data/processed/*
!data/processed/.gitkeep

# Common raw dataset formats, in case they land outside data/ too
*.csv
*.parquet
*.xlsx
!requirements.txt

# ---------------------------------------------------------
# Airflow
# ---------------------------------------------------------
airflow/logs/
airflow/airflow.db
airflow/airflow.cfg
airflow/webserver_config.py
airflow/standalone_admin_password.txt

# ---------------------------------------------------------
# Jupyter notebooks
# ---------------------------------------------------------
.ipynb_checkpoints/
notebooks/*.html

# ---------------------------------------------------------
# Docker
# ---------------------------------------------------------
*.log

# ---------------------------------------------------------
# OS / editor clutter
# ---------------------------------------------------------
.DS_Store
Thumbs.db
.vscode/
.idea/
*.swp